// Miru — schema Prisma cœur (MVP explorer, sans auth).
// Sources : AnimeEntity (domain) et AniListAnime (@miru/anilist).
// Pas de User/Session/Watchlist/Review tant que l'auth n'est pas câblée.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Anime {
  id                String    @id @default(cuid())
  externalAnilistId Int?      @unique
  externalMalId     Int?      @unique
  slug              String    @unique
  title             String
  titleJp           String?
  titleEn           String?
  synopsis          String?   @db.Text
  status            String
  format            String
  episodeCount      Int?
  year              Int?
  coverUrl          String?
  bannerUrl         String?
  trailerUrl        String?
  averageRating     Float?

  studioId          String?
  studio            Studio?   @relation(fields: [studioId], references: [id])
  genres            Genre[]   @relation("AnimeGenres")
  episodes          Episode[]
  characters        AnimeCharacter[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([year])
  @@index([averageRating])
}

model Studio {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  animes Anime[]
}

model Genre {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  animes Anime[] @relation("AnimeGenres")
}

model Episode {
  id        String    @id @default(cuid())
  animeId   String
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  number      Int
  title       String?
  titleJp     String?
  titleRomaji String?
  filler      Boolean  @default(false)
  recap       Boolean  @default(false)
  thumbnail String?
  url       String?
  site      String?
  duration  Int?
  airedAt   DateTime?

  @@unique([animeId, number])
  @@index([animeId])
}

model Character {
  id                String           @id @default(cuid())
  externalAnilistId Int              @unique
  name              String
  nameJp            String?
  imageUrl          String?
  animes            AnimeCharacter[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model VoiceActor {
  id        String           @id @default(cuid())
  name      String           @unique
  animes    AnimeCharacter[]
  createdAt DateTime         @default(now())
}

model AnimeCharacter {
  animeId      String
  characterId  String
  voiceActorId String?
  role         String
  order        Int
  anime        Anime       @relation(fields: [animeId], references: [id], onDelete: Cascade)
  character    Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  voiceActor   VoiceActor? @relation(fields: [voiceActorId], references: [id], onDelete: SetNull)

  @@id([animeId, characterId])
  @@index([animeId])
  @@index([characterId])
}
