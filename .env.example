DATABASE_URL="postgresql://user:password@localhost:5432/miru"

# Generate one with `openssl rand -base64 32`. 32+ characters required.
BETTER_AUTH_SECRET="generate-a-secret"

# Origins for CORS + Better Auth trusted origins / baseURL.
WEB_ORIGIN="http://localhost:3000"
API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Set to "true" to enable cron scheduling (trending daily + episodes hourly).
ENABLE_SCHEDULER=false

# --- Observability (optional in dev, required in prod) ---
# API (server-side errors)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.1"
# SENTRY_RELEASE="" # set by CI from the git sha

# Web — client-side errors. Must start with NEXT_PUBLIC_ to be inlined.
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# Source map upload (CI only). Leave blank to skip.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# Pino log level: "debug" in dev, "info" in prod, "warn" to silence access logs.
# LOG_LEVEL="info"
