// Miru — schema Prisma.
// - Catalog tables (Anime, Studio, Genre, Episode, Character, ...) reflect
//   the AnimeEntity domain and AniList payloads.
// - Better Auth tables (User, Session, Account, Verification) live at the
//   bottom; their model names are mapped in apps/api/src/auth/auth.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Anime {
  id                String  @id @default(cuid())
  externalAnilistId Int?    @unique
  externalMalId     Int?    @unique
  slug              String  @unique
  title             String
  titleJp           String?
  titleEn           String?
  synopsis          String? @db.Text
  status            String
  format            String
  episodeCount      Int?
  year              Int?
  coverUrl          String?
  bannerUrl         String?
  accentHex         String? @db.VarChar(7)
  averageRating     Float?

  syncedAt     DateTime?
  syncFailedAt DateTime?

  studioId   String?
  studio     Studio?           @relation(fields: [studioId], references: [id])
  genres     Genre[]           @relation("AnimeGenres")
  episodes   Episode[]
  characters AnimeCharacter[]
  relations  AnimeRelation[]
  platforms  AnimeOnPlatform[]
  watchlist  WatchlistEntry[]
  reviews    Review[]
  listItems  ListItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([year])
  @@index([averageRating])
  @@index([year, averageRating])
  @@index([syncedAt])
}

model Studio {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  animes Anime[]
}

model Genre {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  animes Anime[] @relation("AnimeGenres")
}

model Episode {
  id          String    @id @default(cuid())
  animeId     String
  anime       Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  number      Int
  title       String?
  titleJp     String?
  titleRomaji String?
  filler      Boolean   @default(false)
  recap       Boolean   @default(false)
  thumbnail   String?
  url         String?
  site        String?
  duration    Int?
  airedAt     DateTime?

  @@unique([animeId, number])
  @@index([animeId])
}

model Character {
  id                String           @id @default(cuid())
  externalAnilistId Int              @unique
  name              String
  nameJp            String?
  imageUrl          String?
  animes            AnimeCharacter[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model VoiceActor {
  id                String           @id @default(cuid())
  externalAnilistId Int?             @unique
  name              String
  animes            AnimeCharacter[]
  createdAt         DateTime         @default(now())

  @@index([name])
}

model AnimeCharacter {
  animeId      String
  characterId  String
  voiceActorId String?
  role         String
  order        Int
  anime        Anime       @relation(fields: [animeId], references: [id], onDelete: Cascade)
  character    Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  voiceActor   VoiceActor? @relation(fields: [voiceActorId], references: [id], onDelete: SetNull)

  @@id([animeId, characterId])
  @@index([animeId])
  @@index([characterId])
}

model AnimeRelation {
  id                       String  @id @default(cuid())
  animeId                  String
  anime                    Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  relatedExternalAnilistId Int
  relationType             String
  title                    String
  coverUrl                 String?
  format                   String?
  year                     Int?

  @@unique([animeId, relatedExternalAnilistId])
  @@index([animeId])
  @@index([relatedExternalAnilistId])
}

model Platform {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  iconUrl String?
  color   String? @db.VarChar(7)
  baseUrl String

  animes AnimeOnPlatform[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnimeOnPlatform {
  animeId    String
  platformId String
  url        String    @db.Text
  source     String    @default("ANILIST") @db.VarChar(16)
  verifiedAt DateTime?

  anime    Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id])

  @@id([animeId, platformId])
  @@index([animeId])
  @@index([platformId])
}

// ---------------------------------------------------------------------------
// Better Auth — managed schema. Do not rename fields without updating
// apps/api/src/auth/auth.ts model name mappings.
// ---------------------------------------------------------------------------

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions  Session[]
  accounts  Account[]
  watchlist WatchlistEntry[]
  reviews   Review[]
  lists     List[]
  listLikes ListLike[]
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// Watchlist — per-user tracking of anime status and progress.
// ---------------------------------------------------------------------------

model WatchlistEntry {
  userId         String
  animeId        String
  status         String    @db.VarChar(16)
  currentEpisode Int       @default(0)
  rating         Int?
  isFavorite     Boolean   @default(false)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@id([userId, animeId])
  @@index([userId])
  @@index([userId, status])
  @@index([animeId])
}

// ---------------------------------------------------------------------------
// Reviews — public rating + comment per (user, anime).
// ---------------------------------------------------------------------------

model Review {
  id        String   @id @default(cuid())
  userId    String
  animeId   String
  rating    Int
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
  @@index([animeId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Lists — user-curated anime lists with ordering, notes, and social likes.
// ---------------------------------------------------------------------------

model List {
  id           String  @id @default(cuid())
  userId       String
  title        String  @db.VarChar(80)
  description  String? @db.Text
  slug         String  @db.VarChar(100)
  isPublic     Boolean @default(true)
  coverArtSeed Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ListItem[]
  likes ListLike[]

  @@unique([userId, slug])
  @@index([userId])
}

model ListItem {
  listId  String
  animeId String
  order   Int
  note    String?  @db.Text
  addedAt DateTime @default(now())

  list  List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@id([listId, animeId])
  @@index([listId, order])
}

model ListLike {
  userId  String
  listId  String
  likedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([userId, listId])
  @@index([listId])
}
