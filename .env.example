## ---------------------------------------------------------------------------
## Required
## ---------------------------------------------------------------------------

# Postgres connection string. Locally we use a Docker container on :5433.
DATABASE_URL="postgresql://miru:miru@localhost:5433/miru"

# Generate one with `openssl rand -base64 32`. 32+ characters required.
BETTER_AUTH_SECRET="generate-a-secret"

## ---------------------------------------------------------------------------
## URLs — adjust for each environment
## ---------------------------------------------------------------------------

# Public origin of the web app. Used as Better Auth trustedOrigin + CORS
# allow-origin.
WEB_ORIGIN="http://localhost:3000"

# Public origin of the API. Used by the web app's auth-client + fetch helpers.
API_BASE_URL="http://localhost:3001"

# Same as API_BASE_URL but inlined into the Next.js bundle (must start with NEXT_PUBLIC_).
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Used by metadataBase + sitemap. In prod set to the canonical https URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

## ---------------------------------------------------------------------------
## Transactional email (Resend)
## ---------------------------------------------------------------------------
## Leave RESEND_API_KEY empty in dev — emails will be logged instead of sent.
## In prod: create an API key at https://resend.com/api-keys.

# RESEND_API_KEY="re_..."

# "From" address. Use Resend's onboarding domain in dev; a verified domain in prod.
MAIL_FROM="Miru <onboarding@resend.dev>"

## ---------------------------------------------------------------------------
## Background jobs
## ---------------------------------------------------------------------------

# "true" → enables crons (sync trending, enrich episodes, notification
# producers). "false" by default to keep dev/CI quiet.
ENABLE_SCHEDULER=false

## ---------------------------------------------------------------------------
## Phase 4 — Per-episode scrapers (Crunchyroll, ADN)
## ---------------------------------------------------------------------------
## OFF by default. Activate ONLY after reviewing
## .claude/docs/scraping-decision.md. Without this flag, no outbound request
## is ever made to crunchyroll.com / animationdigitalnetwork.com.

ENABLE_SCRAPERS=false

## ---------------------------------------------------------------------------
## Observability (optional in dev, recommended in prod)
## ---------------------------------------------------------------------------

# API (server-side errors)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.1"
# SENTRY_RELEASE="" # set by CI from the git sha

# Web — client-side errors. Must start with NEXT_PUBLIC_ to be inlined.
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# Source map upload (CI only). Leave blank to skip.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# Pino log level: "debug" in dev, "info" in prod, "warn" to silence access logs.
# LOG_LEVEL="info"

## ---------------------------------------------------------------------------
## Web Push (optional — leave blank to disable the push toggle)
## ---------------------------------------------------------------------------
## Generate a pair with: `npx web-push generate-vapid-keys`.
## The public key is exposed via GET /push/public-key; the web client
## fetches it before calling pushManager.subscribe().

# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@miru.app"

## ---------------------------------------------------------------------------
## Stripe (Sympathisant subscription — no feature gating)
## ---------------------------------------------------------------------------
## In dev: use Stripe test keys + `stripe listen --forward-to localhost:3001/billing/webhook`
## to receive webhook events locally. The forwarded CLI prints a webhook
## secret (whsec_...) that goes in STRIPE_WEBHOOK_SECRET.

# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PRO_PRICE_ID="price_..."   # Subscription price for the Sympathisant plan
# STRIPE_WEBHOOK_SECRET="whsec_..."
