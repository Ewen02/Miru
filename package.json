{
  "name": "miru",
  "private": true,
  "scripts": {
    "predev": "docker compose up -d --wait && pnpm --filter @miru/db exec prisma migrate deploy && pnpm turbo build --filter=@miru/types --filter=@miru/anilist --filter=@miru/db",
    "dev": "turbo dev",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait && pnpm --filter @miru/db exec prisma db push",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prettier": "^3.4.2",
    "turbo": "^2"
  },
  "packageManager": "pnpm@9.15.0"
}
